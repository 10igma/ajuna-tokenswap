{
  "name": "ajuna-tokenswap",
  "version": "1.0.0",
  "description": "UUPS-upgradeable token wrapper for AJUN Foreign Assets on Polkadot AssetHub",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "clean": "npx hardhat clean",
    "deploy:local": "FOREIGN_ASSET=$FOREIGN_ASSET npx hardhat run scripts/deploy_wrapper.ts --network local",
    "deploy:testnet": "npx hardhat run scripts/deploy_wrapper.ts --network polkadotTestnet",
    "e2e": "./scripts/e2e_local.sh",
    "serve": "./scripts/serve_ui.sh"
  },
  "keywords": [
    "polkadot",
    "erc20",
    "token-wrapper",
    "uups",
    "asset-hub",
    "pallet-revive"
  ],
  "author": "Ajuna Network",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.5",
    "@parity/hardhat-polkadot": "^0.2.7",
    "@polkadot/api": "^16.5.4",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.2.0",
    "chai": "^4.3.10",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.4",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0",
    "@openzeppelin/contracts-upgradeable": "^5.4.0"
  }
}
